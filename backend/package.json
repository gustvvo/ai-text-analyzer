{
  "name": "ai-text-analyzer-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "migrate": "node-pg-migrate -j ts -d DATABASE_URL",
    "migrate:up": "npm run migrate -- up",
    "migrate:down": "npm run migrate -- down"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "node-pg-migrate": "^8.0.4",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
